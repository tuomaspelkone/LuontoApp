<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet-lupa osmdroid-karttatiilien lataukseen -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- GPS-tarkkuussijainti -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Verkkosijainti (varapaikannus) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Askelmittari (Android 10+) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Kamera (lisätään viikolla 4) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Vanhemmille laitteille -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />


    <!-- Tarvitaan Android 10+ (API 29+) askelmittarille -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Vanhemmille laitteille (API < 29) ei tarvita lupaa -->
    <uses-feature
        android:name="android.hardware.sensor.stepcounter"
        android:required="false" />  <!-- false = sovellus toimii ilmankin -->

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:name=".LuontopeliApplication"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Luontopeli">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Luontopeli">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>